# Streamlit のシークレット設定テンプレート
# ----------------------------------------------------------------------------
# ローカル開発: このファイルを `secrets.toml` にリネームして値を埋めてください。
#   .streamlit/secrets.toml
# Streamlit Community Cloud: アプリ管理画面の [Settings] > [Secrets] に
#   下記と同じ内容を貼り付けてください（ファイルのアップロードは不要）。
# ----------------------------------------------------------------------------

# Gemini API キー（https://aistudio.google.com/app/apikey で取得）
GEMINI_API_KEY = "ここにGemini APIキー"

# ----------------------------------------------------------------------------
# GitHub への自動 Push（「📂 Obsidianへ保存」機能）用の設定
# ----------------------------------------------------------------------------
# Personal Access Token（repo 権限付き。https://github.com/settings/tokens で発行）
GITHUB_TOKEN = "ここにGitHubアクセストークン"
# 対象リポジトリ（owner/repo 形式）
GITHUB_REPO = "your-name/your-obsidian-repo"
# プッシュ先ブランチ名
GITHUB_BRANCH = "main"

# ----------------------------------------------------------------------------
# Dropbox 経由でのクラウド完結運用（Streamlit Cloud / GitHub Actions 用）
# 設定するとローカルディスクの代わりに Dropbox 上の Vault を直接読み書きする。
# ----------------------------------------------------------------------------
# OAuth2 App Key / App Secret（https://www.dropbox.com/developers/apps で作成）
DROPBOX_APP_KEY = "ここにDropboxアプリのApp Key"
DROPBOX_APP_SECRET = "ここにDropboxアプリのApp Secret"
# オフラインアクセス用 Refresh Token（App Key/Secret と併用して自動リフレッシュ）
DROPBOX_REFRESH_TOKEN = "ここにDropbox Refresh Token"
# Dropbox 上の Vault ルートパス（例: /Apps/remotely-save/MyVault）
DROPBOX_VAULT_PATH = "/Apps/remotely-save/MyVault"
